# Local development defaults to SQLite. Docker Compose overrides this with PostgreSQL.
DATABASE_URL=sqlite:///./eleicoes2026.db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=eleicoes2026

# LLM Config
# Supported: "gemini", "openai", "mock"
LLM_PROVIDER=mock
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE=
# Gemini's free tier requires a separate Google AI Studio API key.
LLM_MODEL=gemini-2.5-flash-lite

# Embedding Config
# "hash" is dependency-free and works offline. "local" optionally uses
# sentence-transformers when that package and model are available.
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Forecasting Config
DECAY_HALF_LIFE_DAYS=30.0
MONTE_CARLO_ITERATIONS=10000
MONTE_CARLO_SEED=42

# Demo and security controls
DATA_MODE=demo_synthetic
PUBLIC_DEMO=false
ADMIN_ENABLED=true
MAX_UPLOAD_BYTES=10485760
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
